<!--
  TournamentTracker.xml
  GauntletUI prefab for the Tournament Tracker overlay screen.
-->
<Prefab>
  <Window>
    <!-- GauntletUI requires exactly one root widget under Window -->
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent">
      <Children>

        <!-- Full-screen dimmed backdrop -->
        <Widget Id="Backdrop" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Sprite="BlankWhiteSquare_9" Color="#000000FF" AlphaFactor="0.55"/>

        <!-- Centred panel -->
        <Widget Id="Panel" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="780" SuggestedHeight="580" HorizontalAlignment="Center" VerticalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="#1A1320FF" AlphaFactor="0.97">
      <Children>

        <!-- Title -->
        <TextWidget Id="TitleText" Text="@Title" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="52" HorizontalAlignment="Center" VerticalAlignment="Top" Brush="Popup.Title.Text" Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" MarginTop="8"/>

        <!-- Sort button (top-right) -->
        <ButtonWidget Id="SortButton" DoNotPassEventsToChildren="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="180" SuggestedHeight="30" HorizontalAlignment="Right" VerticalAlignment="Top" MarginTop="16" MarginRight="16" Sprite="BlankWhiteSquare_9" Color="#3A2A20FF" Command.Click="ExecuteCycleSort">
          <Children>
            <TextWidget Text="@SortLabel" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="Popup.Button.Text" Brush.FontColor="#F8E3BEFF" Brush.FontSize="16" Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center"/>
          </Children>
        </ButtonWidget>

        <!-- Gold accent divider below title -->
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="2" VerticalAlignment="Top" MarginTop="60" MarginLeft="20" MarginRight="20" Sprite="BlankWhiteSquare_9" Color="#A37434FF"/>

        <!-- Column headers -->
        <Widget Id="HeaderRow" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="32" VerticalAlignment="Top" MarginTop="66">
          <Children>
            <TextWidget Id="ColTown" Text="Town" WidthSizePolicy="Fixed" SuggestedWidth="180" HeightSizePolicy="StretchToParent" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center" MarginLeft="16"/>
            <TextWidget Id="ColPrize" Text="Prize" WidthSizePolicy="Fixed" SuggestedWidth="240" HeightSizePolicy="StretchToParent" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center" MarginLeft="200"/>
            <TextWidget Id="ColValue" Text="Value" WidthSizePolicy="Fixed" SuggestedWidth="100" HeightSizePolicy="StretchToParent" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center" MarginLeft="444"/>
            <TextWidget Id="ColDist" Text="Dist." WidthSizePolicy="Fixed" SuggestedWidth="90" HeightSizePolicy="StretchToParent" HorizontalAlignment="Right" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center" MarginRight="16"/>
          </Children>
        </Widget>

        <!-- Thin divider line below headers -->
        <Widget Id="Divider" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="1" VerticalAlignment="Top" MarginTop="98" MarginLeft="12" MarginRight="12" Sprite="BlankWhiteSquare_9" Color="#A37434FF" AlphaFactor="0.4"/>

        <!-- No tournaments message -->
        <TextWidget Id="EmptyLabel" Text="@NoTournamentsText" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="40" VerticalAlignment="Top" HorizontalAlignment="Center" MarginTop="180" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center" IsHidden="@HasTournaments"/>

        <!-- Scrollable tournament list -->
        <Widget Id="ScrollContainer" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="420" VerticalAlignment="Top" MarginTop="102" MarginLeft="4" MarginRight="4" IsHidden="@HasNoTournaments">
          <Children>
            <ScrollablePanel Id="TournamentScroll" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" AutoHideScrollBars="true" ClipRect="ClipRect" InnerPanel="ClipRect\TournamentList" VerticalScrollbar="..\ScrollbarHolder\VerticalScrollbar">
              <Children>
                <Widget Id="ClipRect" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" ClipContents="true">
                  <Children>
                    <ListPanel Id="TournamentList" DataSource="{Tournaments}" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="VerticalBottomToTop">
                      <ItemTemplate>
                        <Widget Id="Row" WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed" SuggestedHeight="44" Sprite="BlankWhiteSquare_9" Color="#25192CFF" MarginBottom="2">
                          <Children>
                            <TextWidget Id="RowTown" Text="@TownName" WidthSizePolicy="Fixed" SuggestedWidth="180" HeightSizePolicy="StretchToParent" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center" MarginLeft="16"/>
                            <TextWidget Id="RowPrize" Text="@PrizeName" WidthSizePolicy="Fixed" SuggestedWidth="240" HeightSizePolicy="StretchToParent" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Left" Brush.TextVerticalAlignment="Center" MarginLeft="200"/>
                            <TextWidget Id="RowValue" Text="@PrizeValue" WidthSizePolicy="Fixed" SuggestedWidth="100" HeightSizePolicy="StretchToParent" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center" MarginLeft="444"/>
                            <TextWidget Id="RowDist" Text="@DistanceText" WidthSizePolicy="Fixed" SuggestedWidth="90" HeightSizePolicy="StretchToParent" HorizontalAlignment="Right" Brush="Popup.Description.Text" Brush.TextHorizontalAlignment="Right" Brush.TextVerticalAlignment="Center" MarginRight="16"/>
                          </Children>
                        </Widget>
                      </ItemTemplate>
                    </ListPanel>
                  </Children>
                </Widget>
              </Children>
            </ScrollablePanel>

            <Widget Id="ScrollbarHolder" WidthSizePolicy="Fixed" SuggestedWidth="16" HeightSizePolicy="StretchToParent" HorizontalAlignment="Right">
              <Children>
                <ScrollbarWidget Id="VerticalScrollbar" WidthSizePolicy="CoverChildren" HeightSizePolicy="StretchToParent" AlignmentAxis="Vertical" Handle="ScrollbarHandle" MarginTop="4" MarginBottom="4" MaxValue="100" MinValue="0">
                  <Children>
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent" SuggestedWidth="2" HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="#A37434FF" AlphaFactor="0.5"/>
                    <ImageWidget Id="ScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" MinHeight="15" SuggestedHeight="30" SuggestedWidth="10" HorizontalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="#A37434FF"/>
                  </Children>
                </ScrollbarWidget>
              </Children>
            </Widget>
          </Children>
        </Widget>

        <!-- Footer button -->
        <ButtonWidget Id="CloseButton" DoNotPassEventsToChildren="true" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="140" SuggestedHeight="42" HorizontalAlignment="Center" VerticalAlignment="Bottom" MarginBottom="12" Sprite="BlankWhiteSquare_9" Color="#3A2A20FF" Command.Click="ExecuteClose">
          <Children>
            <TextWidget Text="Close" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="Popup.Button.Text" Brush.FontColor="#F8E3BEFF" Brush.TextHorizontalAlignment="Center" Brush.TextVerticalAlignment="Center"/>
          </Children>
        </ButtonWidget>

      </Children>
    </Widget>

      </Children>
    </Widget>
  </Window>
</Prefab>
